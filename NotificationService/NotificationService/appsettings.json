{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceBus": {
    "ConnectionString": "PLACEHOLDER_SERVICE_BUS_CONNECTION_STRING",
    "ApplicationStatusQueueName": "application-status-changed"
  },
  "Smtp": {
    "Host": "PLACEHOLDER_SMTP_HOST",
    "Port": 587,
    "Username": "PLACEHOLDER_SMTP_USERNAME",
    "Password": "PLACEHOLDER_SMTP_PASSWORD",
    "FromAddress": "noreply@dogadoption.example.com",
    "FromName": "Dog Adoption Center"
  }
}
